<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/bg_casino"
    android:padding="20dp">

    <!-- MONEDAS -->
    <TextView
        android:id="@+id/txtCoins"
        android:text="@string/coins_initial"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- REELS -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/reel1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:src="@drawable/cherry"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/reel2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:src="@drawable/lemon"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/reel3"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_margin="10dp"
            android:src="@drawable/diamond"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- RESULTADO -->
    <TextView
        android:id="@+id/txtResult"
        android:text="@string/empty"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFD700"
        android:layout_marginBottom="25dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- SPIN -->
    <Button
        android:id="@+id/btnSpin"
        android:text="@string/spin"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#FFD700"
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp" />

    <!-- BOTÓN RECARGA -->
    <Button
        android:id="@+id/btnResetCoins"
        android:text="@string/reload_coins"
        android:textColor="#FFFFFF"
        android:backgroundTint="#28A745"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp" />

    <!-- SALIR -->
    <Button
        android:id="@+id/btnExit"
        android:text="@string/exit"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6C757D"
        android:layout_width="180dp"
        android:layout_height="wrap_content" />

</LinearLayout>